#Alertmanager
TG_SERVER_URL=localhost:9094

#Prometheus
PROMETHEUS_VERSION=2.45.0
ALERTMANAGER_VERSION=0.26.0

#Rules
DEBUG_RULE=sum(rate(echo_requests_total{code="500"}[1m]))>0
PROD_RULE=sum(rate(echo_requests_total{code="500"}[5m])) / sum(rate(echo_requests_total[5m]))>0.1

#Compose
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
